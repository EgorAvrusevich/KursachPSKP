# Используем официальный образ Ubuntu 20.04
FROM ubuntu:20.04

# Отключаем интерактивные диалоги при установке
ENV DEBIAN_FRONTEND=noninteractive

# Обновляем систему и устанавливаем зависимости для Node.js
RUN apt-get update && apt-get install -y \
    curl \
    gnupg \
    build-essential \
    && curl -fsSL https://deb.nodesource.com/setup_18.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Создаем рабочую директорию
WORKDIR /usr/src/app

# Копируем файлы манифеста зависимостей
COPY package*.json ./

# Устанавливаем зависимости Node.js
RUN npm install

# Копируем исходный код проекта
COPY . .

# Открываем порт, на котором работает Express/Node.js приложение
EXPOSE 3000

# Команда запуска приложения
CMD ["npm", "start"]